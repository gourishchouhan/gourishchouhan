---
// Modern header component with a sleek, centered navigation bar
---

<header
  class="fixed top-10 left-0 right-0 z-40 flex justify-center p-4 transition-all duration-300"
>
  <nav
    id="nav"
    class="flex items-center gap-4 bg-pink-300/80 backdrop-blur-lg rounded-[2rem] border-4 border-black shadow-lg px-4 py-3 transition-all duration-300 tilt-chaos"
  >
    <!-- Hamburger (visible only on small screens) -->
    <button
      id="menu-toggle"
      class="sm:hidden w-8 h-8 flex flex-col justify-center items-center space-y-1"
      aria-label="Toggle navigation"
    >
      <span class="w-5 h-0.5 bg-gray-700 dark:bg-gray-300"></span>
      <span class="w-5 h-0.5 bg-gray-700 dark:bg-gray-300"></span>
      <span class="w-5 h-0.5 bg-gray-700 dark:bg-gray-300"></span>
    </button>

    <!-- Nav links -->
    <ul
      id="nav-links"
      class="hidden sm:flex items-center gap-2 sm:gap-4 flex-col sm:flex-row"
    >
      <li><a href="#about" class="nav-link">About???</a></li>
      <li><a href="#projects" class="nav-link">Epic Stuff</a></li>
      <li><a href="#skills" class="nav-link">Power Level</a></li>
      <li><a href="#contact" class="nav-link">Spam Me</a></li>
      <li>
        <a
          href="/Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link-button"
        >
          Resume LOL
        </a>
      </li>
    </ul>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      class="theme-toggle-button"
      aria-label="Toggle dark mode"
    >
      <svg
        id="theme-icon-light"
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
        />
      </svg>
      <svg
        id="theme-icon-dark"
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
        />
      </svg>
    </button>
  </nav>
</header>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const lightIcon = document.getElementById('theme-icon-light');
  const darkIcon = document.getElementById('theme-icon-dark');

  const applyTheme = (theme: string) => {
    if (theme === 'dark') {
      html.classList.add('dark');
      lightIcon!.style.display = 'none';
      darkIcon!.style.display = 'block';
    } else {
      html.classList.remove('dark');
      lightIcon!.style.display = 'block';
      darkIcon!.style.display = 'none';
    }
  };

  const currentTheme = localStorage.getItem('theme') || 'light';
  applyTheme(currentTheme);

  toggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    const newTheme = isDark ? 'dark' : 'light';
    localStorage.setItem('theme', newTheme);
    applyTheme(newTheme);
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    header?.classList.toggle('scrolled', window.scrollY > 50);
  });

  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const navLinks = document.getElementById('nav-links');
  const nav = document.getElementById('nav');

  menuToggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('hidden');
    navLinks?.classList.toggle('flex');
    nav?.classList.toggle('rounded-full');
    nav?.classList.toggle('rounded-xl');
    nav?.classList.toggle('flex-col');
    nav?.classList.toggle('items-start');
    nav?.classList.toggle('py-4');
  });
</script>

<style>
  .nav-link {
    @apply text-sm sm:text-base font-bold transition-colors duration-200 px-2 py-1 rounded-md;
    color: #111827;
    background: rgba(255, 255, 255, 0.5);
    border: 2px solid #111827;
  }
  .nav-link-button {
    @apply text-sm sm:text-base text-black px-4 py-1.5 rounded-full transition-colors duration-200 font-bold;
    background: linear-gradient(135deg, #ffe600, #ff8500);
    border: 3px solid #111827;
  }
  .theme-toggle-button {
    @apply w-10 h-10 rounded-full flex items-center justify-center transition-colors duration-200;
    color: #111827;
    background: rgba(255, 255, 255, 0.55);
    border: 3px solid #111827;
  }
  #theme-icon-dark {
    display: none;
  }
  .dark #theme-icon-light {
    display: none;
  }
  .dark #theme-icon-dark {
    display: block;
  }
  header.scrolled nav {
    box-shadow: 0 10px 0 rgba(0, 0, 0, 0.95);
  }
</style>
