---
// Modern projects section with sample projects
const projects = [
  {
    title: "RaiseIt",
    description: "RaiseIt is a web platform where users can voice concerns & find support.",
    technologies: ["React", "Node.js", "MongoDB", "Vanta.js"],
    github: "https://github.com/kalviumcommunity/S65_Gourish_Chouhan_Capstone_RaiseIt",
    live: "https://raiseit-phi.vercel.app",
    image: "/raiseit.png"
  },
  {
    title: "Whispr",
    description: "An open-source chat application. Get secure end-to-end encypted chats and groups",
    technologies: ["Next.js", "Socket.io", "MongoDB", "Tailwind"],
    github: "https://github.com/cometerm/whispr",
    live: "https://whispr-gilt.vercel.app/",
    image: "/whispr.png"
  },
  {
    title: "Imaverter",
    description: "An image utility tool for conversion, corner cropping, and compression.",
    technologies: ["Next.js", "Colourjs.io", "kmeans"],
    github: "https://github.com/armancurr/imaverter",
    live: "https://imaverter.vercel.app/",
    image: "/imaverter.png"
  }
];
---

<section id="projects" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-noise-grid opacity-25"></div>
  <div class="absolute left-8 top-12 text-7xl animate-bounce">🚨</div>
  <div class="absolute right-10 bottom-16 text-8xl animate-pulse">🛸</div>
  <div class="container-custom">
    <!-- Section header -->
    <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-black mb-6 gradient-text">
          Epic Internet Creations
        </h2>
        <p class="text-lg md:text-xl text-black max-w-3xl mx-auto text-balance font-bold">
          Observe these spectacular builds with loud cards, bright badges, and enough visual confidence to make a 2007 forum blush.
        </p>
    </div>
    
    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <div class="card card-hover group animate-on-scroll overflow-hidden" style={`animation-delay: ${index * 200}ms`}>
          <!-- Project image -->
          <div class="relative overflow-hidden bg-secondary-100 dark:bg-secondary-700 h-48">
            <img src={project.image} alt={project.title + ' preview'} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-br from-pink-500/40 to-cyan-400/30 mix-blend-multiply pointer-events-none"></div>
            <div class="absolute left-2 top-2 rounded-full border-2 border-black bg-yellow-300 px-3 py-1 text-xs font-black uppercase text-black">Certified Banger</div>
            <!-- Overlay with links -->
            <div class="absolute inset-0 bg-secondary-900/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center space-x-4">
              <a 
                href={project.github} 
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 bg-white/10 rounded-full hover:bg-white/20 transition-colors duration-200 border-2 border-white"
                aria-label="View source code"
              >
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
              <a 
                href={project.live} 
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 bg-white/10 rounded-full hover:bg-white/20 transition-colors duration-200 border-2 border-white"
                aria-label="View live demo"
              >
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
          
          <!-- Project content -->
          <div class="p-6">
            <h3 class="text-xl font-semibold text-black mb-3 transition-colors duration-300">
              {project.title} !!!
            </h3>
            <p class="text-black mb-4 text-sm leading-relaxed font-bold">
              {project.description}
            </p>
            
            <!-- Technologies -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.technologies.map((tech) => (
                <span class="px-2 py-1 text-xs font-bold bg-pink-200 text-black rounded border-2 border-black tilt-chaos">
                  {tech}
                </span>
              ))}
            </div>
            
            <!-- Project links -->
            <div class="flex space-x-3">
              <a 
                href={project.github} 
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 btn-ghost text-sm justify-center"
              >
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Code Flex
              </a>
              <a 
                href={project.live} 
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 btn-primary text-sm justify-center"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Beam Me Up
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <div class="ascii-panel text-xs leading-relaxed">
        <pre>{String.raw`project ranking algorithm:
1. does it work?
2. does it look cool?
3. can it survive being placed on this cursed page?
4. if yes -> featured project`}</pre>
      </div>
      <div class="fake-window static popup-float max-w-none">
        <div class="fake-window-bar">
          <span>breaking news</span>
          <span>24/7</span>
        </div>
        <div class="p-4 text-sm font-bold text-black">
          Analysts confirm each project card gained at least 73 percent more drama after the introduction of aggressive gradients and random labels.
        </div>
      </div>
    </div>
  </div>
</section>
